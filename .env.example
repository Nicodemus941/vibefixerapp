# Rebuild Engine - environment variables (Phase 1)
# Copy to .env.local for local dev. Never commit real keys.

# --- Database (Supabase Postgres via Prisma) ---
# Pooled connection (used by app runtime). pgbouncer mode.
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct connection (used by Prisma migrations).
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# --- Supabase API (auth + client) ---
NEXT_PUBLIC_SUPABASE_URL="https://PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_..."
SUPABASE_SERVICE_ROLE_KEY="service_role_..."

# --- Claude (Anthropic) ---
ANTHROPIC_API_KEY="sk-ant-..."
# Pin the model so cost/perf is predictable. Override per-call as needed.
ANTHROPIC_MODEL_AUDIT="claude-sonnet-4-6"
ANTHROPIC_MODEL_CLASSIFY="claude-haiku-4-5-20251001"

# --- Scraping ---
FIRECRAWL_API_KEY="fc-..."

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Rebuild Engine"

# --- Inngest (Phase 2 job runner) ---
# In local dev, leave these unset and run `npx inngest-cli@latest dev` — the dev
# server connects to /api/inngest with no auth. Set both in production.
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""
