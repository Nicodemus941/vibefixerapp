# =============================================================================
# F.A.S.T. Family Autoglass — environment variables
# =============================================================================
# Copy this file to .env.local for local dev, or set these in your Vercel
# dashboard (Project Settings → Environment Variables) for production.
#
# The site WORKS without any of these set — quote submissions just log to
# the server console. Add these to enable real lead notifications.
# =============================================================================


# ---- Email lead alerts to Eric (Resend) -------------------------------------
# Sign up at https://resend.com (free tier: 100 emails/day, 3000/month).
# Quickest path:
#   1. Create a Resend account
#   2. Verify ONE recipient email (e.g. fastfamilyautoglass@gmail.com) under
#      Resend > Audiences, OR verify the domain fastfamilyautoglass.com under
#      Resend > Domains (preferred — lets you send from any address @ that domain).
#   3. Create an API key under Resend > API Keys and paste it below.
RESEND_API_KEY=

# Where the lead alert is delivered. Defaults to fastfamilyautoglass@gmail.com.
LEAD_EMAIL_TO=fastfamilyautoglass@gmail.com

# Sender. If you have NOT verified your own domain in Resend, leave this as
# the default (Resend's onboarding sender works for verified single recipients).
# Once you verify the domain, switch to e.g. "F.A.S.T. Quotes <quotes@fastfamilyautoglass.com>".
LEAD_EMAIL_FROM=F.A.S.T. Quotes <onboarding@resend.dev>


# ---- SMS to Eric + customer auto-reply (Twilio) -----------------------------
# Optional but recommended — gets Eric a text notification within seconds and
# auto-texts the customer "we got it, calling you back."
# Sign up at https://twilio.com, buy a 10DLC-registered number, then:
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=+15551234567

# Eric's mobile in E.164 (e.g. +19419990551). New leads SMS go here.
LEAD_SMS_TO=+19419990551
